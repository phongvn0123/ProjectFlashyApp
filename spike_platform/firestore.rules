// NOT DEPLOYABLE BY DESIGN. This ruleset is intentionally NOT referenced by
// firebase.json — the top-level "firestore" block was removed so that a stray
// `firebase deploy` can never push these wide-open rules to the team's shared
// Firebase project (5 developers share one Spark project; see CLAUDE.md).
// The local emulator does not need this file: with no rules configured it
// already defaults to allowing all reads and writes.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissive baseline for local Firebase Emulator Suite use only
    // (Phase 0 spike scope). Production security rules are deferred to
    // Phase 1 — see 00-01-PLAN.md Open Question #2 resolution.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
